# exDASH frontend -> exDASH backend
# Works in Docker production because Express serves UI and API from the same origin.
# Works in local Vite dev because vite.config.ts proxies /api to http://localhost:4000.
VITE_EXDASH_API_URL=/api/exdash

# exDASH server runtime
# NODE_ENV is set by Dockerfile for container runtime. Do not set it here;
# Vite only supports NODE_ENV=development in .env during local builds.
PORT=4000
SERVE_STATIC=true
TRUST_PROXY=true

# Optional. Set only if the frontend calls the API from another origin.
# CORS_ORIGIN=http://localhost:5173

# External finance data source.
# Local FSDS database. This host name works when exDASH runs in the same Docker
# network as the empowerx-fsds-db-local service/container.
FSDS_DB_DRIVER=postgres
FSDS_DB_HOST=empowerx-fsds-db-local
FSDS_DB_PORT=5432
FSDS_DB_DATABASE=empowerx_fsds
FSDS_DB_SCHEMA=public
FSDS_DB_USER=exdash_readonly
FSDS_DB_PASSWORD=exdashpassword
FSDS_DB_SSL=false
FSDS_DB_SSL_REJECT_UNAUTHORIZED=true
FSDS_DB_AMOUNT_SCALE=100

# Pool/timing controls
FSDS_DB_POOL_MAX=10
FSDS_DB_CONNECTION_TIMEOUT_MS=10000
FSDS_DB_STATEMENT_TIMEOUT_MS=30000

# Alternative single-string DB config. If set, it overrides host/port/database/user/password.
# FSDS_DB_CONNECTION_STRING=postgres://exdash_readonly:<password>@<host>:5432/empowerx_fsds?sslmode=require

# exDASH metadata database.
# Stores dashboard templates, saved dashboards, financial scenarios, and assumptions.
EXDASH_DB_HOST=exdash-db-local
EXDASH_DB_PORT=5432
EXDASH_DB_DATABASE=exdash_metadata
EXDASH_DB_USER=exdash
EXDASH_DB_PASSWORD=exdash_dev
EXDASH_DB_SSL=false
EXDASH_DB_SSL_REJECT_UNAUTHORIZED=true
EXDASH_DB_POOL_MAX=10
