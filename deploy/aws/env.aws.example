# exDASH container/runtime
NODE_ENV=production
PORT=4000
SERVE_STATIC=true
TRUST_PROXY=true

# If UI and API are served by the same exDASH service, keep this relative path.
VITE_EXDASH_API_URL=/api/exdash

# Optional. Use this if the API is called from another domain.
# CORS_ORIGIN=https://exdash.empowerx.example.gov.ph,https://empowerx.example.gov.ph

# exDASH backend -> AWS-hosted EMPOWERX FSDS PostgreSQL
FSDS_DB_DRIVER=postgres
FSDS_DB_HOST=<aws-rds-or-aurora-postgresql-endpoint>
FSDS_DB_PORT=5432
FSDS_DB_DATABASE=empowerx_fsds
FSDS_DB_SCHEMA=public
FSDS_DB_USER=exdash_readonly
FSDS_DB_PASSWORD=<store-in-aws-secrets-manager-not-plain-env>

# AWS RDS/Aurora PostgreSQL should normally require TLS from app workloads.
FSDS_DB_SSL=true
FSDS_DB_SSL_REJECT_UNAUTHORIZED=true

# Optional if your RDS CA is not already trusted by the runtime image.
# Mount the CA bundle and point to it:
# FSDS_DB_SSL_CA_FILE=/app/certs/aws-rds-ca-bundle.pem
# Or inject the CA text directly:
# FSDS_DB_SSL_CA=-----BEGIN CERTIFICATE-----...

# The analyzed FSDS dump stores money as bigint centavos.
FSDS_DB_AMOUNT_SCALE=100

# Pool/timing controls.
FSDS_DB_POOL_MAX=10
FSDS_DB_CONNECTION_TIMEOUT_MS=10000
FSDS_DB_STATEMENT_TIMEOUT_MS=30000

# Alternative single-string connection. If set, it overrides host/port/database/user/password.
# FSDS_DB_CONNECTION_STRING=postgres://exdash_readonly:<password>@<endpoint>:5432/empowerx_fsds?sslmode=require
